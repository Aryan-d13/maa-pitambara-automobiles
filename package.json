{
  "name": "maa-pitambara-automobiles",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter \"@mp-auto/*\" --parallel dev",
    "build": "pnpm --filter \"@mp-auto/*\" build && node -e \"const fs = require('fs'); fs.cpSync('apps/web/.next', '.next', { recursive: true, force: true })\"",
    "start": "pnpm --filter \"@mp-auto/*\" start"
  },
  "devDependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
